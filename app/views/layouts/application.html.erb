<!DOCTYPE html>
<html>
  <head>
    <meta name="turbo-cache-control" content="no-cache">
    <title><%= content_for(:title) || "Bookers2" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://kit.fontawesome.com/3aa8ad2fa9.js" crossorigin="anonymous"></script>
    <%= javascript_importmap_tags %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body class="app">

    <!-- ===== Header ===== -->
    <header class="app-header shadow-sm">
      <nav class="navbar navbar-expand-lg navbar-dark bg-dark app-header__nav">
        <div class="container app-header__container">

          <!-- ロゴ -->
          <a class="navbar-brand app-header__brand" href="/">
            <span class="app-header__brand-text">Bookers</span>
          </a>

          <!-- ハンバーガー -->
          <button class="navbar-toggler app-header__toggler" type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#navbarNavDropdown">
            <span class="navbar-toggler-icon"></span>
          </button>

          <!-- メニュー -->
          <div class="collapse navbar-collapse app-header__menu" id="navbarNavDropdown">
            <ul class="navbar-nav ms-auto app-header__list">

              <% if authenticated? %>

                <li class="app-header__item">
                  <%= link_to user_path(Current.user),
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-house app-header__icon"></i> Home
                  <% end %>
                </li>

                <li class="app-header__item">
                  <%= link_to users_path,
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-users app-header__icon"></i> Users
                  <% end %>
                </li>

                <li class="app-header__item">
                  <%= link_to books_path,
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-book-open app-header__icon"></i> Books
                  <% end %>
                </li>

                <li class="app-header__item">
                  <%= link_to session_path,
                      data: { turbo_method: :delete },
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-right-from-bracket app-header__icon"></i> Log out
                  <% end %>
                </li>

              <% else %>

                <li class="app-header__item">
                  <%= link_to root_path,
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-house app-header__icon"></i> Home
                  <% end %>
                </li>

                <li class="app-header__item">
                  <%= link_to about_path,
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-link app-header__icon"></i> About
                  <% end %>
                </li>

                <li class="app-header__item">
                  <%= link_to new_user_path,
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-user-plus app-header__icon"></i> Sign up
                  <% end %>
                </li>

                <li class="app-header__item">
                  <%= link_to new_session_path,
                      class: "nav-link text-light app-header__link" do %>
                    <i class="fa-solid fa-right-to-bracket app-header__icon"></i> Log in
                  <% end %>
                </li>

              <% end %>
            </ul>
          </div>
        </div>
      </nav>

      <!-- ===== 検索エリア ===== -->
      <% if authenticated? %>
<div class="container mt-2 app-header__search">
  <div class="d-flex justify-content-center align-items-center app-header__search-inner">

    <!-- 通常検索 -->
    <%= form_with url: search_path, method: :get, local: true,
        class: "d-flex align-items-center gap-2 app-header__search-form" do |f| %>

      <%= f.text_field :keyword,
          placeholder: "検索ワード",
          class: "form-control app-header__input" %>

      <%= f.select :model,
          options_for_select([["User","user"],["Book","book"]]),
          class: "form-select app-header__select" %>

      <%= f.select :method,
          options_for_select([["完全一致", "perfect"],["前方一致", "forward"],["後方一致", "backward"],["部分一致", "partial"]]),
          class: "form-select app-header__select" %>

      <%= f.submit "検索",
          class: "app-header__submit" %>
    <% end %>

    <!-- スペース -->
    <div class="app-header__search-gap mx-3"></div>

    <!-- タグ検索 -->
    <%= form_with url: search_path, method: :get, local: true,
        class: "d-flex align-items-center gap-2 app-header__tag-form" do |f| %>

      <%= f.text_field :tag,
          placeholder: "タグで検索",
          class: "form-control app-header__input" %>

      <%= f.submit "検索",
          class: "app-header__submit" %>
    <% end %>

  </div>
</div>
      <% end %>
    </header>

    <!-- ===== フラッシュ ===== -->
    <div class="app-flash">
      <%= flash[:notice] %>
    </div>

    <!-- ===== エラー ===== -->
    <div class="container app-error">
      <div class="row justify-content-center">
        <div class="app-error__inner">

          <% if @error_messages.present? %>
            <div class="app-error__box">
              <h2 class="app-error__title">
                <%= @error_messages.count %> errors prohibited this from being saved:
              </h2>
              <ul class="app-error__list">
                <% @error_messages.each do |message| %>
                  <li class="app-error__item"><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

        </div>
      </div>
    </div>

    <!-- ===== メイン ===== -->
    <main class="app-main">
      <%= yield %>
    </main>

    <!-- ===== フッター ===== -->
    <footer class="app-footer">
      <div class="container mt-5 app-footer__container">
        <div class="row">
          <div class="col text-center app-footer__inner">
            <p class="app-footer__text">CopyRight Infratop.inc</p>
          </div>
        </div>
      </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

  </body>
</html>