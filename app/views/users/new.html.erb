<div class="container signup">
  <div class="row justify-content-center signup__row">
    <div class="col-sm-12 col-md-8 col-lg-5 px-5 px-sm-0 signup__inner">

      <h2 class="signup__title">Sign up</h2>

      <%= form_with model: @user, url: users_path, class: "signup__form" do |f| %>

        <% if @user.errors.any? %>
          <div id="error_explanation" class="signup__errors">
            <h2 class="signup__error-title">
              <%= pluralize(@user.errors.count, "error") %> prohibited this user from being saved:
            </h2>
            <ul class="signup__error-list">
              <% @user.errors.full_messages.each do |msg| %>
                <li class="signup__error-item"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="signup__group">
          <%= f.label :name, class: "signup__label" %>
          <%= f.text_field :name,
              autofocus: true,
              class: "form-control signup__input" %>
        </div>

        <div class="signup__group">
          <%= f.label :email, class: "signup__label" %>
          <%= f.email_field :email_address,
              class: "form-control signup__input" %>
        </div>

        <div class="signup__group">
          <%= f.label :password, class: "signup__label" %>
          <p class="signup__hint">(6 characters minimum)</p>
          <%= f.password_field :password,
              class: "form-control signup__input" %>
        </div>

        <div class="signup__group">
          <%= f.label :password_confirmation, class: "signup__label" %>
          <%= f.password_field :password_confirmation,
              class: "form-control signup__input" %>
        </div>

        <div class="signup__actions">
          <%= f.submit "Sign up",
              class: "btn btn-sm btn-success signup__submit" %>
        </div>

      <% end %>

      <div class="signup__links">
        <%= link_to "Log in",
            new_session_path,
            class: "signup__link" %>
      </div>

    </div>
  </div>
</div>