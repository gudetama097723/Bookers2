<div class="container px-5 px-sm-0">
	<div class="row">

  <div class="col-md-3">
    <%= render "users/user_info", user: @user %>
    <%= render "books/form", book: @book %>
  </div>

<div class="col-md-8 offset-md-1">
<h2>Books</h2>

<table class="table table-hover table-inverse">
  <thead>
  <tr>
    <th></th>
    <th>Title</th>
	  <th>Opinion</th>
    <th colspan="3"></th>
  </tr>
  </thead>

  <tbody>
  <% @books.each do |book| %>
  <tr>
  <td>
  <%= link_to user_path(book.user) do %>
  <% if @user.profile_image.attached? %>
    <%= image_tag @user.profile_image, size: "100x100" %>
  <% else %>
    <%= image_tag 'noimage.jpg', size: "100x100" %>
  <% end %>
  <% end %>
  </td>

  <td><%= link_to book.title, book_path(book) %></td>

  <td><%= book.body %></td>
  </tr>
  <% end %>
  </tbody>

</table>

  <div>
    <h2>投稿数の前日比・前週比</h2>
  </div>

<table class="table table-bordered text-center">

  <thead class="table-light">
  <tr>
    <th>今日の投稿数</th>
    <th>昨日の投稿数</th>
    <th>前日比</th>
  </tr>
  </thead>

  <tbody>
  <tr>
    <td><%= @today_count %></td>
    <td><%= @yesterday_count %></td>
    <td><%= @day_ratio.present? ? "#{@day_ratio}" : "-" %>%</td>
  </tr>
  </tbody>

</table>


<table class="table table-bordered text-center">


  <thead class="table-light">
  <tr>
    <th>今週の投稿数</th>
    <th>先週の投稿数</th>
    <th>前週比</th>
  </tr>
  </thead>

  <tbody>
  <tr>
    <td><%= @this_week_count %></td>
    <td><%= @last_week_count %></td>
    <td><%= @week_ratio.present? ? "#{@week_ratio}%" : "—" %>%</td>
  </tr>
  </tbody>
</table>

</div>

</div>
</div>
