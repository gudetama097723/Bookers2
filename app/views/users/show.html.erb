<%if @book.errors.any? %>
  <%= @book.errors.count %>error prohibited this book from being saved:
  <ul>
    <% @book.errors.full_messages.each do |message|%>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<h2>User info</h2>
  <% if @user.image.attached? %>
    <%= image_tag @user.image, size: "100x100" %>
  <% else %>
    <%= image_tag 'noimage.jpg', size: "100x100" %>
  <% end %>
<p>name</p>
  <div><%= @user.name %></div>
<p>introduction</p>
  <div><%= @user.introduction %></div>

<%= link_to "編集", edit_user_path %>

<h2>New book</h2>
<%= form_with model: @book do |f|%>
  <p>Title</p>
    <%= f.text_field :title %>
  <p>Opinion</p>
    <%= f.text_field :body %><br>
    <%= f.submit "Create Book" %>
<% end %>


<h2>Books</h2>
<% @books.each do |book| %>
  <p><%= book.title %></p>
  <p><%= book.body %></p>
<% end %>