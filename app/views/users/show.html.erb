<%if @book.errors.any? %>
  <%= @book.errors.count %>error prohibited this book from being saved:
  <ul>
    <% @book.errors.full_messages.each do |message|%>
      <li><%= message %></li>
    <% end %>
  </ul>
<% end %>

<h2>User info</h2>



<h2>New book</h2>
<%= form_with model: @book do |f|%>
  <p>Title</p>
    <%= f.text_field :title %>
  <p>Opinion</p>
    <%= f.text_field :body %><br>
    <%= f.submit "Create Book" %>
<% end %>


<h2>Books</h2>
<% @books.each do |book| %>
  <p><%= book.title %></p>
  <p><%= book.body %></p>
<% end %>