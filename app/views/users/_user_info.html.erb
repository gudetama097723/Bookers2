
<h2>User info</h2>
<table>
  <tr>
  <% if user.profile_image.attached? %>
    <%= image_tag user.profile_image, size: "100x100" %>
  <% else %>
    <%= image_tag 'noimage.jpg', size: "100x100" %>
  <% end %>
  </tr>
  <tr>
    <th>name</th>
    <th><%= user.name %></th>
  </tr>
  <tr>
    <th>introduction</th>
    <th><%= user.introduction %></th>
  </tr>
  <tr>
  <th>follows</th>
  <th><%= link_to user.followings.count, followings_user_path(user) %></th>
  </tr>
  <tr>
  <th>followers</th>
  <th><%= link_to user.followers.count, followers_user_path(user) %></th>
  </tr>
</table>
    <% if Current.user != user %>
      <% if Current.user.following?(user) %>
        <%= link_to "フォロー解除",
        user_relationships_path(user),
        data: { turbo_method: :delete },
        class: "btn btn-danger" %>
      <% else %>
        <%= link_to "フォロー",
          user_relationships_path(user),
          data: { turbo_method: :post },
          class: "btn btn-primary"%>
      <% end %>
    <% end %>

    <% if Current.user != user && 
          Current.user.following?(user) && 
          user.following?(Current.user)%>

      <%= button_to "チャットを始める", rooms_path(user_id: user.id), class: "btn btn-success" %>
    <% end%>

  <%= link_to edit_user_path(user), class: "btn btn-outline-secondary btn-sm w-100" do %>
  <i class="fa-solid fa-user-gear"></i>

<% end %>


