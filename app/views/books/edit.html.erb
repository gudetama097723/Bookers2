<div class="container book-edit">
  <div class="row justify-content-center book-edit__row">
    <div class="col-md-6 book-edit__inner">


<h1 class="book-edit__title">Editing Book</h1>

<%= form_with model: @book, class: "book-edit__form" do |f| %>

  <% if @book.errors.any? %>
    <div id="error_explanation" class="book-edit__errors">
      <h2 class="book-edit__error-title">
      <%= pluralize(@book.errors.count, "error") %> prohibited this book from being saved:
      </h2>
      <ul class="book-edit__error-list">
        <% @book.errors.full_messages.each do |msg| %>
          <li class="book-edit__error-item"><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="book-edit__group">
    <label class="book-edit__label">Title</label>
    <%= f.text_field :title, class: "form-control book-edit__input"%>
  </div>

  <div class="book-edit__group">
    <label class="book-edit__label">Opinion</label>
    <%= f.text_area :body, class: "form-control book-edit__textarea"%>
  </div>

  <div class="book-edit__group">
    <label class="book-edit__label">Tags</label>
    <%= f.text_field :tag_names, placeholder: "タグをカンマ区切りで入力", class: "form-control book-edit__input" %>
  </div>

  <div class="book-edit__actions">
    <%= f.submit "Update Book", class: "book-edit__submit" %>
  </div>

  <% end %>

  <div class="book-edit__links">
    <%= link_to "Show", book_path(@book.id), class: "book-edit__link" %> |
    <%= link_to "Back", books_path, class: "book-edit__link" %>
  </div>

    </div>
  </div>
</div>