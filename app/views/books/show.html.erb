<h2>Book detail</h2>

  <% if @book.user.image.attached? %>
    <%= image_tag @book.user.image, size: "100x100" %>
  <% else %>
    <%= image_tag 'noimage.jpg', size: "100x100" %>
  <% end %>
  <%= link_to @book.user.name, user_path(@book.user) %>
  <p><%= @book.title %></p>
  <p><%= @book.body %></p>
  <% if @book.user == Current.user %>
  <%= link_to "Edit", edit_book_path(@book) %>
  <%= button_to "destroy", book_path(@book), method: :delete %>
  <% end %>

  
