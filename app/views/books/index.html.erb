<div class="container px-5 px-sm-0">
	<div class="row">

  <div class="col-md-2">
    <%= render "users/user_info", user: Current.user %>
    <%= render "books/form", book: Book.new %>
  </div>

<div class="col-md-10">
<h2>Books</h2>
<%= link_to "新着順", books_path(sort: "new") %> |
<%= link_to "評価の高い順", books_path(sort: "rate") %>
<table class="table table-hover table-inverse">

  <thead>
  <tr>
    <th></th>
    <th>Title</th>
    <th>Opinion</th>
    <th>Tag</th>
    <th></th><th></th><th></th><th></th>
  </tr>
  </thead>

  <tbody>
  <% @books.each do |book| %>
  <tr>
  <td>
    <%= link_to user_path(book.user) do %>
    <% if book.user.profile_image.attached? %>
      <%= image_tag book.user.profile_image, size: "100x100" %>
    <% else %>
      <%= image_tag "noimage.jpg", size: "100x100" %>
    <% end %>
    <% end %>
  </td>
  <td><%= link_to book.title, book_path(book) %></td>
  <td><%= book.body %></td>
  <td>
  <% book.tags.each do |tag| %>
    <%= link_to tag.name, books_path(tag: tag.name) %>
  <% end %>
  </td>
  <td>
      <%= render "favorites/favorite_btn", book: book %>
  </td>
  <td><p>コメント数：<%= book.book_comments.count %></p></td>
  <td>閲覧数： <%= book.view_count %></td>
  <td><div class="raty-readonly" data-score="<%= book.rating %>"></div></td>
  </tr>
  <% end %>
  </tbody>
  </table>
</div>

  </div>
</div>