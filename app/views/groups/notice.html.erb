<div class="d-flex justify-content-center align-items-center group-mail">
  <div class="text-center group-mail__inner">

    <h2 class="group-mail__title">Event Mail</h2>

    <%= form_with url: send_notice_group_path(@group),
        method: :post,
        data: { turbo: false },
        class: "group-mail__form" do %>

      <div class="group-mail__group">
        <%= label_tag :title, "Title", class: "group-mail__label" %>
        <%= text_field_tag :title,
            nil,
            class: "form-control group-mail__input" %>
      </div>

      <div class="group-mail__group">
        <%= label_tag :body, "Content", class: "group-mail__label" %>
        <%= text_area_tag :body,
            nil,
            class: "form-control group-mail__textarea" %>
      </div>

      <div class="group-mail__actions">
        <%= submit_tag "送信",
            class: "btn btn-primary group-mail__submit" %>
      </div>

    <% end %>

  </div>
</div>