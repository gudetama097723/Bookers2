<div class="d-flex justify-content-center align-items-center group-create">
  <div class="text-center group-create__inner">

    <h1 class="group-create__title">Create Group</h1>

    <%= form_with model: @group, class: "group-create__form" do |f| %>

      <div class="group-create__group">
        <label class="group-create__label">グループ名</label>
        <%= f.text_field :name,
            class: "form-control group-create__input" %>
      </div>

      <div class="group-create__group">
        <label class="group-create__label">紹介文</label>
        <%= f.text_area :introduction,
            class: "form-control group-create__textarea" %>
      </div>

      <div class="group-create__group">
        <label class="group-create__label">グループ画像</label>
        <%= f.file_field :image,
            class: "form-control group-create__file" %>
      </div>

      <div class="group-create__actions">
        <%= f.submit "作成",
            class: "btn btn-success group-create__submit" %>
      </div>

    <% end %>

  </div>
</div>